# =========================================================
# .gitignore … Gitで「記録しなくてよいファイル」を書くファイル
# ここに書いたものは commit の対象から外れます。
# =========================================================

# Windowsが勝手に作る設定ファイル(中身は不要なので無視する)
Thumbs.db
desktop.ini

# macOSが勝手に作る設定ファイル
.DS_Store

# エディタが作る一時ファイルなど
*.tmp
*.log
